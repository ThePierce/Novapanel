{
	"name": "novapanel",
	"version": "1.1.5",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:standalone": "NODE_ENV=development DATA_DIR=.data node server.js",
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . --max-warnings 0",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"preview": "vite preview",
		"start": "NODE_ENV=production node server.js",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.2.14",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"eslint": "^10.4.1",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^16.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^6.0.0",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@tabler/icons-webfont": "^3.24.0",
		"busboy": "^1.6.0",
		"dotenv": "^16.6.1",
		"express": "^4.21.1",
		"fast-xml-parser": "^5.8.0",
		"hls.js": "^1.6.16",
		"ws": "^8.20.1",
		"yaml": "^2.9.0"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.2"
		}
	}
}
